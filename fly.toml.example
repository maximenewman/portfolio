# Copy to fly.toml and set app to your Fly.io app name, or generate with: fly launch
# https://fly.io/docs/reference/configuration/

app = 'YOUR_APP_NAME'
primary_region = 'yyz'

[build]

[http_service]
  internal_port = 3000
  force_https = true
  auto_stop_machines = 'stop'
  auto_start_machines = true
  min_machines_running = 0
  processes = ['app']

[[vm]]
  memory = '1gb'
  cpu_kind = 'shared'
  cpus = 1
  memory_mb = 1024
